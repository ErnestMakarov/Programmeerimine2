<Window x:Class="KooliProjekt.WpfApplication.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KooliProjekt.WpfApplication"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="ToDoListsDataGrid" 
                  Grid.Column="0"
                  AutoGenerateColumns="True"
                  ItemsSource="{Binding Data}"
                  SelectedItem="{Binding SelectedItem}"/>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock>ID</TextBlock>
            <TextBlock Text="{Binding SelectedItem.Id}"></TextBlock>
            <TextBlock>Name</TextBlock>
            <TextBox Text="{Binding SelectedItem.Name}"></TextBox>
            <TextBlock Text="Budget"/>
            <TextBox Text="{Binding SelectedItem.Budget}"></TextBox>
            <TextBlock Text="StartDate"/>
            <TextBox Text="{Binding SelectedItem.StartDate}"></TextBox>
            <TextBlock Text="DueDate"/>
            <TextBox Text="{Binding SelectedItem.DueDate}"></TextBox>
            <TextBlock Text="PricePerHour"/>
            <TextBox Text="{Binding SelectedItem.PricePerHour}"></TextBox>
            <StackPanel 
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="10">
                    <Button Margin="5" Padding="5" Command="{Binding AddNewCommand}">New</Button>
                    <Button Margin="5" Padding="5" 
                Command="{Binding SaveCommand}" 
                CommandParameter="{Binding SelectedItem}">Save</Button>
                <Button Margin="5" Padding="5"
                Command="{Binding DeleteCommand}" 
                CommandParameter="{Binding SelectedItem}">Delete</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
